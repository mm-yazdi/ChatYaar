<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!--Background color-->
    <Color x:Key="Background">#0F0F1A</Color>
    <Color x:Key="Surface">#1E1E2E</Color>
    <Color x:Key="SurfaceRaised">#252538</Color>

    <!--Main colors-->
    <Color x:Key="Primary">#3B82F6</Color>
    <Color x:Key="PrimaryDark">#2563EB</Color>
    <Color x:Key="UserBubble">#1D4ED8</Color>

    <!--Text color-->
    <Color x:Key="TextPrimary">#F0F0F8</Color>
    <Color x:Key="TextSecondary">#A0A0B8</Color>
    <Color x:Key="TextMuted">#5A5A72</Color>


    <Color x:Key="Border">#12FFFFFF</Color>

    <Color x:Key="ShadowColor">#66000000</Color>

    <Color x:Key="Success">#10B981</Color>
    <Color x:Key="Warning">#F59E0B</Color>

    <!--Button color-->
    <Color x:Key="IconColor">#A0A0B8</Color>
    <Color x:Key="IconColorActive">#3B82F6</Color>
    <Color x:Key="LikeActive">#10B981</Color>
    <Color x:Key="DislikeActive">#EF4444</Color>
</ResourceDictionary>